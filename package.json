{
  "name": "flipper",
  "version": "1.0.0",
  "description": "Albion Online Black Market Flipper",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "node build_prod.js",
    "postinstall": "electron-builder install-app-deps"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "body-parser": "^2.2.2",
    "express": "^5.2.1",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "electron": "^40.7.0",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9",
    "javascript-obfuscator": "^5.3.0"
  },
  "build": {
    "appId": "com.markettracer.flipper",
    "productName": "Market Tracer",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/unnamed.jpg"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "extraResources": [
      "MarketTracerSniffer.exe"
    ],
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "compression": "maximum"
  }
}